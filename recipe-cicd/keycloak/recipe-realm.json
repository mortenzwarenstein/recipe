{
  "realm": "recipe",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      { "name": "ROLE_USER", "composite": false },
      { "name": "ROLE_ADMIN", "composite": false }
    ]
  },
  "clients": [
    {
      "clientId": "recipe-client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": ["http://localhost:4200/*"],
      "webOrigins": ["+"]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": true
        }
      ],
      "realmRoles": ["ROLE_USER", "ROLE_ADMIN"]
    }
  ]
}
