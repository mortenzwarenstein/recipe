{
  "realm": "recipe",
  "displayName": "Recipe App",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": true,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "recipe-client",
      "name": "Recipe Client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "https://recipes.mortenzwarenstein.nl/*",
        "https://mortenzwarenstein.nl/*",
        "https://tenmore.nl/*"
      ],
      "webOrigins": [
        "https://recipes.mortenzwarenstein.nl",
        "https://mortenzwarenstein.nl",
        "https://tenmore.nl"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "ROLE_USER",
        "description": "Regular user"
      },
      {
        "name": "ROLE_ADMIN",
        "description": "Administrator"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": true
        }
      ],
      "realmRoles": [
        "ROLE_USER",
        "ROLE_ADMIN"
      ]
    }
  ]
}
